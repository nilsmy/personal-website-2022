	issn = {2079-3200},
	url = {https://www.mdpi.com/2079-3200/13/3/26},
	doi = {10.3390/jintelligence13030026},
	abstract = {Divergent thinking tests are popular instruments to measure a person’s creativity. They often involve scoring fluency, which refers to the count of ideas generated in response to a prompt. The two-parameter Poisson counts model (2PPCM), a generalization of the Rasch Poisson counts model (RPCM) that includes discrimination parameters, has been proposed as a useful approach to analyze fluency scores in creativity tasks, but its estimation was presented in the context of generalized structural equation modeling (GSEM) commercial software (e.g., Mplus). Here, we show how the 2PPCM (and RPCM) can be estimated in a Bayesian multilevel regression framework and interpreted using the R package brms, which provides an interface for the Stan programming language. We illustrate this using an example dataset, which contains fluency scores for three tasks and 202 participants. We discuss model specification, estimation, convergence, fit and comparisons. Furthermore, we provide instructions on plotting item response functions, comparing models, calculating overdispersion and reliability, as well as extracting factor scores.},
	language = {en},
	number = {3},
	urldate = {2025-02-23},
	journal = {Journal of Intelligence},
	publisher = {Multidisciplinary Digital Publishing Institute},
	author = {Myszkowski, Nils and Storme, Martin},
	month = mar,
	year = {2025},
	note = {Number: 3},
	keywords = {psychometrics, creativity, item response theory, divergent thinking, Bayesian estimation, fluency},
	pages = {26},
	file = {Full Text PDF:/Users/nils/Zotero/storage/9WIICDVD/Myszkowski and Storme - 2025 - Bayesian Estimation of Generalized Log-Linear Poisson Item Response Models for Fluency Scores Using.pdf:application/pdf},
}

@article{myszkowski_one_2025,
	title = {One {Score}, {Two} {Components}: {Disentangling} {Appropriateness} and {Originality} in {PISA} {Creative} {Thinking} {Judgments} {Using} {Generalized} {Item} {Response} {Tree} {Models}},
	volume = {59},
	issn = {0022-0175, 2162-6057},
	shorttitle = {One {Score}, {Two} {Components}},
	url = {https://onlinelibrary.wiley.com/doi/10.1002/jocb.70033},
	doi = {10.1002/jocb.70033},
	abstract = {In the PISA 2022 creative thinking test, students provide a response to a prompt, which is then coded by human raters as no credit, partial credit, or full credit. Like many large-scale educational testing frameworks, PISA uses the generalized partial credit model (GPCM) as a response model for these ordinal ratings. In this paper, we show that the instructions given to the raters violate some assumptions of the GPCM as it is used: Raters are instructed to rate according to steps that involve multiple attributes (appropriateness and diversity/originality), with a different (set of) attribute(s) necessary to pass the different thresholds of the scoring scale. Instead of the GPCM, we propose multidimensional generalized item response tree models that allow us to account for the sequential nature of the ratings and to disentangle the attributes measured from the original scores. We discuss advantages, limitations, as well as recommendations for future research.},
	language = {en},
	number = {2},
	urldate = {2025-05-31},
	journal = {The Journal of Creative Behavior},
	author = {Myszkowski, Nils and Storme, Martin},
	month = jun,
	year = {2025},
	pages = {e70033},
	file = {PDF:/Users/nils/Zotero/storage/6KY9SFB9/Myszkowski and Storme - 2025 - One Score, Two Components Disentangling Appropriateness and Originality in PISA Creative Thinking J.pdf:application/pdf},
}

@article{gollub_correlates_2025-1,
	title = {Correlates of higher trust in public health officials: results from a representative cohort of private university undergraduates},
	volume = {63},
	issn = {0264-410X},
	shorttitle = {Correlates of higher trust in public health officials},
	url = {https://www.sciencedirect.com/science/article/pii/S0264410X25009077},
	doi = {10.1016/j.vaccine.2025.127610},
	abstract = {Background
University students' COVID-19 vaccination attitudes and decisions are shaped by their trust in health-related information and its sources. Few studies have identified factors associated with trust in public health officials among university students. We sought to identify these factors in a representative cohort of private university undergraduates in New York State.
Methods
We used two-stage sampling to recruit a representative sample of 233 private university undergraduates from January–May 2022. Students completed a cross-sectional online survey with questions on trust in public health officials, socio-demographics, and COVID-19 vaccine beliefs and attitudes. Logistic regression was used to identify factors associated with trust in public health officials.
Results
Of 233 participants, 162 were women (73 \%) and 110 were White (47 \%). Three-quarters of participants had high trust in public health officials (n = 170, 76 \%). Women were five times as likely (adjusted odds ratio [aOR] = 4.5, 95 \% confidence interval [CI]: 2.0–10.3) and White students had 60 \% reduced odds (aOR = 0.4, 95 \% CI: 0.2–0.9) of reporting high levels of trust in public health officials, compared to men and non-White students, respectively. Students who did not report religious concerns were three times as likely (aOR = 3.4; 95 \% CI: 1.5–7.9) and students who were not concerned about long-term side-effects of COVID-19 vaccination were four times as likely (aOR = 3.5; 95 \% CI: 1.4–8.8) to report high levels of trust in public health officials compared to students with concerns.
Conclusion
Our results differed from previous findings on the effects of race/ethnicity on vaccine hesitancy and medical mistrust, potentially reflecting high education and family income, heightened risk perception among racial minorities, and effective messaging in our sample and study setting. Further targeted messaging on vaccine safety and effectiveness would benefit students, with a particular focus on men, White students, students with religious concerns regarding vaccines, and students with low trust in institutions and leaders recommending vaccination.},
